// Kelly Campaign Command Calendar — owned schema: kelly_calendar
// Step 5 foundation. Do not place tables in public.
// Live mutations require Step 4 AUTH-RBAC.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["kelly_calendar"]
}

