/// Server-side OAuth state (short-lived). Never store authorization codes.
model GoogleOAuthPendingState {
  id              String   @id @default(cuid())
  state           String   @unique
  codeVerifier    String
  createdByUserId String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([expiresAt])
  @@schema("kelly_calendar")
}

model GoogleCalendarConnection {
  id                          String                 @id @default(cuid())
  googleAccountEmail          String?
  googleAccountSubject        String?
  googleCalendarId            String                 @default("primary")
  refreshTokenCiphertext      String
  refreshTokenIv              String
  refreshTokenAuthTag         String
  encryptionVersion           String                 @default("v1")
  grantedScopes               String[]
  connectionStatus            GoogleConnectionStatus @default(NOT_CONNECTED)
  connectedByUserId           String?
  connectedAt                 DateTime?
  lastTokenRefreshAt          DateTime?
  lastTokenRefreshFailureAt   DateTime?
  lastSyncStartedAt           DateTime?
  lastSyncCompletedAt         DateTime?
  lastSyncStatus              SyncStatus             @default(NOT_CONFIGURED)
  lastSyncErrorCode           String?
  /// Opaque Google sync token for incremental sync (not a secret credential).
  syncCursor                  String?
  historicalImportedThrough   DateTime?
  pendingReconcileCount       Int                    @default(0)
  revokedAt                   DateTime?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  externalSourceId            String?                @unique

  externalSource ExternalCalendarSource? @relation(fields: [externalSourceId], references: [id])

  @@index([connectionStatus])
  @@schema("kelly_calendar")
}

model CampaignTravelLeg {
  id                     String                @id @default(cuid())
  fromEventId            String?
  toEventId              String?
  originLabel            String?
  destinationLabel       String?
  originPlaceId          String?
  destinationPlaceId     String?
  departureWindowStart   DateTime?
  arrivalWindowEnd       DateTime?
  distanceMeters         Int?
  durationSeconds        Int?
  routeProvider          String                @default("GOOGLE_ROUTES")
  routeTruthType         RouteTruthType        @default(GOOGLE_ROUTE_ESTIMATE)
  providerRequestVersion String?
  computedAt             DateTime              @default(now())
  confidence             String                @default("MEDIUM")
  reviewStatus           TravelLegReviewStatus @default(UNREVIEWED)
  ambiguityReason        String?
  excludedReason         String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  fromEvent Event? @relation("TravelLegFrom", fields: [fromEventId], references: [id])
  toEvent   Event? @relation("TravelLegTo", fields: [toEventId], references: [id])

  @@index([fromEventId, toEventId])
  @@index([routeTruthType])
  @@index([reviewStatus])
  @@schema("kelly_calendar")
}

/// V2.1 Campaign Mission — projection store for Event → Mission.
/// Additive only. Does not replace Event scheduling behavior.
model CampaignMission {
  id                   String                   @id @default(cuid())
  sourceEventId        String                   @unique
  sourceEventNumber    String
  sourceEventVersion   Int
  projectionVersion    String                   @default("v2.1.0")
  attendTitle          String
  objective            String?
  objectiveSource      String                   @default("UNKNOWN")
  successCriteria      Json
  missionStatus        MissionOperationalStatus @default(DRAFT)
  lifecyclePhase       MissionLifecyclePhase    @default(PREPARE)
  intelligence         Json
  completeness         Json
  startsAt             DateTime
  endsAt               DateTime
  timezone             String                   @default("America/Chicago")
  operatorOwnedFields  String[]                 @default([])
  projectedAt          DateTime                 @default(now())
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  sourceEvent  Event               @relation(fields: [sourceEventId], references: [id], onDelete: Restrict)
  preparation  MissionPreparation?
  execution    MissionExecution?
  debrief      MissionDebrief?
  followUp     MissionFollowUp?
  travelPlan   MissionTravelPlan?
  logisticsPack MissionLogisticsPack?
  fieldOpsSession MissionFieldOpsSession?
  staffingPlan MissionStaffingPlan?
  communications CampaignCommunication[]
  incidents    MissionIncident[]

  @@index([missionStatus])
  @@index([lifecyclePhase])
  @@index([startsAt, endsAt])
  @@index([sourceEventNumber])
  @@schema("kelly_calendar")
}

/// V2.1 Prepare Mode — operator-owned briefing (1:1 with CampaignMission).
/// Additive. Never stores Event schedule fields. Survives Mission reprojection.
model MissionPreparation {
  id                   String                      @id @default(cuid())
  missionId            String                      @unique
  briefingSummary      String?
  strategicPurpose     String?
  desiredImpression    String?
  keyMessage           String?
  openingApproach      String?
  closingApproach      String?
  questionsToAsk       Json                        @default("[]")
  talkingPoints        Json                        @default("[]")
  thingsToNotice       Json                        @default("[]")
  sensitivities        Json                        @default("[]")
  commitmentsToAvoid   Json                        @default("[]")
  storiesOrExamples    Json                        @default("[]")
  peopleBriefings      Json                        @default("[]")
  organizationBriefings Json                       @default("[]")
  logisticsNotes       String?
  arrivalInstructions  String?
  parkingInstructions  String?
  entryContact         String?
  attireNotes          String?
  accessibilityNotes   String?
  travelNotes          String?
  lodgingNotes         String?
  materialsNeeded      Json                        @default("[]")
  preparationTasks     Json                        @default("[]")
  operatorNotes        String?
  readinessState       MissionPreparationReadiness @default(DRAFT)
