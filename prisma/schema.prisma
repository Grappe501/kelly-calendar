model MissionIncident {
  id                      String                     @id @default(cuid())
  missionId               String
  campaignDateKey         String
  /// Stable non-sensitive reference, unique within campaignDateKey.
  incidentRef             String
  category                MissionIncidentCategory    @default(OTHER)
  severity                MissionIncidentSeverity    @default(MODERATE)
  status                  MissionIncidentStatus      @default(OPEN)
  summary                 String
  description             String?
  observedAt              DateTime
  reportedAt              DateTime                   @default(now())
  reportedByUserId        String?
  locationLabel           String?
  sensitivity             MissionIncidentSensitivity @default(STANDARD)
  immediateActionSummary  String?
  ownerName               String?
  ownerUserId             String?
  carryForwardRequired    Boolean                    @default(false)
  carriedForwardAt        DateTime?
  carriedForwardByUserId  String?
  followUpRequired        Boolean                    @default(false)
  /// Soft durable link to MissionFollowUpAction (not FK — avoids cross-layer cascade risk).
  linkedFollowUpActionId  String?
  linkedFollowUpImportKey String?
  stabilizedAt            DateTime?
  stabilizedByUserId      String?
  resolvedAt              DateTime?
  resolvedByUserId        String?
  closedAt                DateTime?
  closedByUserId          String?
  archivedAt              DateTime?
  archivedByUserId        String?
  isArchived              Boolean                    @default(false)
  createdByUserId         String?
  updatedByUserId         String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  mission          CampaignMission                   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  updates          MissionIncidentUpdate[]
  acknowledgements MissionIncidentAcknowledgement[]

  @@unique([campaignDateKey, incidentRef])
  @@index([missionId])
  @@index([campaignDateKey])
  @@index([status])
  @@index([severity])
  @@index([sensitivity])
  @@index([isArchived])
  @@schema("kelly_calendar")
}

model MissionIncidentUpdate {
  id                String                   @id @default(cuid())
  incidentId        String
  updateType        MissionIncidentUpdateType
