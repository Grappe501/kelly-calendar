  recipientConfirmedByUserId     String?
  evidenceSummaryJson            Json                           @default("{}")
  evidenceHash                   String
  createdAt                      DateTime                       @default(now())
  finalizedAt                    DateTime?
  finalizedByUserId              String?

  execution CommunicationLiveTestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@schema("kelly_calendar")
}

model CommunicationLiveTestPostReview {
  id                         String                      @id @default(cuid())
  programId                  String
  executionId                String                      @unique(map: "CommunicationLiveTestPostReview_execution")
  status                     CommLiveTestPostReviewStatus @default(NOT_STARTED)
  providerReviewJson         Json                        @default("{}")
  deliverabilityReviewJson   Json                        @default("{}")
  webhookReviewJson          Json                        @default("{}")
  suppressionReviewJson      Json                        @default("{}")
  securityReviewJson         Json                        @default("{}")
  productionBlockReviewJson  Json                        @default("{}")
  incidentSummaryJson        Json                        @default("{}")
  lessonsLearned             String?
  recommendedNextStep        String?
  reviewedByUserId           String?
  approvedByUserId           String?
  createdAt                  DateTime                    @default(now())
  completedAt                DateTime?
  evidenceHash               String

  program   CommunicationLiveTestProgram   @relation(fields: [programId], references: [id], onDelete: Cascade)
  execution CommunicationLiveTestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@schema("kelly_calendar")
}

model CommunicationLiveTestIncident {
  id                     String                      @id @default(cuid())
  programId              String
  executionId            String?
  severity               CommLiveTestIncidentSeverity @default(WARNING)
  incidentType           String
  status                 CommLiveTestIncidentStatus   @default(OPEN)
  summary                String
  evidenceJson           Json                         @default("{}")
  containmentActionsJson Json                         @default("[]")
  resolutionNotes        String?
  createdByUserId        String?
  createdAt              DateTime                     @default(now())
  resolvedAt             DateTime?
  resolvedByUserId       String?

  program CommunicationLiveTestProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@schema("kelly_calendar")
}


