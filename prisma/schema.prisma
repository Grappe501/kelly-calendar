  @@schema("kelly_calendar")
}

model ApprovalAction {
  id                String   @id @default(cuid())
  approvalRequestId String
  actorUserId       String?
  action            String
  comment           String?
  createdAt         DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id])

  @@schema("kelly_calendar")
}

model AuditLog {
