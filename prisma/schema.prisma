  newStatus         MissionIncidentStatus?
  previousSeverity  MissionIncidentSeverity?
  newSeverity       MissionIncidentSeverity?
  sensitivity       MissionIncidentSensitivity @default(STANDARD)
  createdAt         DateTime                 @default(now())

  incident MissionIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([occurredAt, recordedAt, id])
  @@index([updateType])
  @@schema("kelly_calendar")
}

model MissionIncidentAcknowledgement {
  id                   String                                     @id @default(cuid())
  incidentId           String
