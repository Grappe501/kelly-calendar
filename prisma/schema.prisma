  status                      TaskStatus        @default(NOT_STARTED)
  notes                       String?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt

  travelPlan EventTravelPlan @relation(fields: [travelPlanId], references: [id])

  @@schema("kelly_calendar")
}

model EventBriefing {
  id        String   @id @default(cuid())
  eventId   String
  title     String
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

model EventLink {
  id        String   @id @default(cuid())
  eventId   String
  label     String
  url       String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

model EventFile {
  id           String   @id @default(cuid())
  eventId      String
  fileName     String
  storageKey   String?
  contentType  String?
  sensitivity  String   @default("INTERNAL")
  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

model EventNote {
  id        String   @id @default(cuid())
  eventId   String
  noteType  String   @default("PRIVATE")
  body      String
  createdByUserId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

model EventOutcome {
  id        String   @id @default(cuid())
  eventId   String
  summary   String?
  lessons   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

model EventFollowup {
  id             String     @id @default(cuid())
  eventId        String
  title          String
  assignedUserId String?
  dueAt          DateTime?
  status         TaskStatus @default(NOT_STARTED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@schema("kelly_calendar")
}

// ─── D. People / orgs ────────────────────────────────────────────────

model Person {
  id                    String    @id @default(cuid())
  displayName           String
  firstName             String?
  lastName              String?
  preferredName         String?
  title                 String?
  organizationId        String?
  publicEmail           String?
  privateEmailEncrypted String?
  publicPhone           String?
  privatePhoneEncrypted String?
  notes                 String?
  externalCrmId         String?
  externalSystem        String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  archivedAt            DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id])
  eventPeople  EventPerson[]
  contactMethods ContactMethod[]

  @@schema("kelly_calendar")
}

model Organization {
  id             String    @id @default(cuid())
  name           String
  organizationType String?
  websiteUrl     String?
  city           String?
  countyId       String?
  state          String    @default("Arkansas")
  externalCrmId  String?
  externalSystem String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  people             Person[]
  eventOrganizations EventOrganization[]
  county             ArkansasCounty? @relation(fields: [countyId], references: [id])

  @@schema("kelly_calendar")
}

model EventPerson {
  id       String          @id @default(cuid())
  eventId  String
  personId String
  role     PersonEventRole @default(OTHER)

  event  Event  @relation(fields: [eventId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([eventId, personId, role])
  @@schema("kelly_calendar")
}

model EventOrganization {
  id             String @id @default(cuid())
  eventId        String
  organizationId String
  role           String @default("HOST")

  event        Event        @relation(fields: [eventId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([eventId, organizationId])
  @@schema("kelly_calendar")
}

model ContactMethod {
  id        String  @id @default(cuid())
  personId  String
  method    String
  value     String
  isPrivate Boolean @default(true)

  person Person @relation(fields: [personId], references: [id])

  @@schema("kelly_calendar")
}

// ─── E. Geography ────────────────────────────────────────────────────

model ArkansasRegion {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  isActive Boolean @default(true)

  counties ArkansasCounty[]
  events   Event[]
  places   Place[]

  @@schema("kelly_calendar")
}

model ArkansasCounty {
  id       String  @id @default(cuid())
  fipsCode String  @unique
  name     String
  slug     String  @unique
  regionId String?
  isActive Boolean @default(true)

  region        ArkansasRegion? @relation(fields: [regionId], references: [id])
  events        Event[]
  places        Place[]
  organizations Organization[]
  geographies   EventGeography[]

  @@schema("kelly_calendar")
}

model Place {
  id                       String             @id @default(cuid())
  name                     String
  placeType                String?
  venueName                String?
  streetAddress            String?
  city                     String?
  countyId                 String?
  state                    String             @default("Arkansas")
  postalCode               String?
  regionId                 String?
  latitude                 Float?
  longitude                Float?
  locationDisclosureDefault LocationDisclosure @default(CITY)
  isPrivate                Boolean            @default(false)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  archivedAt               DateTime?

  county      ArkansasCounty?  @relation(fields: [countyId], references: [id])
  region      ArkansasRegion?  @relation(fields: [regionId], references: [id])
  geographies EventGeography[]

  @@schema("kelly_calendar")
}

model EventGeography {
  id       String  @id @default(cuid())
  eventId  String
  countyId String?
  placeId  String?

  event  Event           @relation(fields: [eventId], references: [id])
  county ArkansasCounty? @relation(fields: [countyId], references: [id])
  place  Place?          @relation(fields: [placeId], references: [id])

  @@schema("kelly_calendar")
}

// ─── F. Historical import ────────────────────────────────────────────

model ExternalCalendarSource {
  id                         String          @id @default(cuid())
  provider                   ExternalProvider @default(GOOGLE_CALENDAR)
  sourceType                 String
  displayName                String
  sourceFingerprint          String          @unique
  externalCalendarIdEncrypted String?
  sourceUrlEncrypted         String?
  syncDirection              SyncDirection   @default(IMPORT_ONLY)
  syncStatus                 SyncStatus      @default(NOT_CONFIGURED)
  historicalFloor            DateTime
  lastSuccessfulImportAt     DateTime?
  lastAttemptAt              DateTime?
  lastErrorCode              String?
  lastErrorSummary           String?
  createdByUserId            String?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  disabledAt                 DateTime?

  importRuns         CalendarImportRun[]
  externalIdentities ExternalEventIdentity[]

  @@schema("kelly_calendar")
}

model CalendarImportRun {
  id              String          @id @default(cuid())
  externalSourceId String
  requestedStart  DateTime
  requestedEnd    DateTime
  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  status          ImportRunStatus @default(STARTED)
  fetchedCount    Int             @default(0)
  parsedCount     Int             @default(0)
  normalizedCount Int             @default(0)
  stagedCount     Int             @default(0)
  approvedCount   Int             @default(0)
  rejectedCount   Int             @default(0)
  duplicateCount  Int             @default(0)
  errorCount      Int             @default(0)
  manifestJson    Json?
  operatorUserId  String?
  requestId       String?
  createdAt       DateTime        @default(now())

  externalSource ExternalCalendarSource @relation(fields: [externalSourceId], references: [id])
  records        CalendarImportRecord[]

  @@index([status])
  @@schema("kelly_calendar")
}

model CalendarImportRecord {
  id                      String                 @id @default(cuid())
  importRunId             String
  externalEventIdentityId String?
  rawFingerprint          String
  normalizedPayload       Json?
  proposedEventPayload    Json?
  reviewStatus            HistoricalReviewStatus @default(UNREVIEWED)
  duplicateStatus         DuplicateStatus        @default(NEW)
  canonicalEventId        String?
  reviewedByUserId        String?
  reviewedAt              DateTime?
  reviewNotes             String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  importRun       CalendarImportRun      @relation(fields: [importRunId], references: [id])
  canonicalEvent  Event?                 @relation(fields: [canonicalEventId], references: [id])
  duplicateMatches CalendarImportDuplicateMatch[] @relation("ImportRecord")
  matchedAs        CalendarImportDuplicateMatch[] @relation("MatchedRecord")
  reviewActions    CalendarImportReviewAction[]

  @@index([reviewStatus])
  @@index([duplicateStatus])
  @@schema("kelly_calendar")
}

model CalendarImportDuplicateMatch {
  id                String          @id @default(cuid())
  importRecordId    String
  matchedRecordId   String?
  status            DuplicateStatus
  reasons           String[]
  createdAt         DateTime        @default(now())

  importRecord  CalendarImportRecord  @relation("ImportRecord", fields: [importRecordId], references: [id])
  matchedRecord CalendarImportRecord? @relation("MatchedRecord", fields: [matchedRecordId], references: [id])

  @@schema("kelly_calendar")
}

model CalendarImportReviewAction {
  id             String   @id @default(cuid())
  importRecordId String
  actorUserId    String?
  action         String
  notes          String?
  createdAt      DateTime @default(now())

  importRecord CalendarImportRecord @relation(fields: [importRecordId], references: [id])

  @@schema("kelly_calendar")
}

model ExternalEventIdentity {
  id                   String           @id @default(cuid())
  provider             ExternalProvider @default(GOOGLE_CALENDAR)
  externalSourceId     String
  externalEventId      String?
  iCalUid              String?
  recurringEventId     String?
  originalOccurrenceAt DateTime?
  sourceSequence       Int?
  sourceUpdatedAt      DateTime?
  canonicalEventId     String?
  fingerprint          String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  externalSource ExternalCalendarSource @relation(fields: [externalSourceId], references: [id])
  canonicalEvent Event?                 @relation(fields: [canonicalEventId], references: [id])

  @@unique([externalSourceId, fingerprint])
  @@index([externalSourceId, externalEventId])
  @@index([iCalUid])
  @@schema("kelly_calendar")
}

// ─── G. Templates ────────────────────────────────────────────────────

model EventTemplate {
  id                          String               @id @default(cuid())
  slug                        String               @unique
  name                        String
  description                 String?
  primaryCalendarType         CalendarType
  eventType                   String?
  defaultDurationMinutes      Int                  @default(60)
  defaultVisibility           EventVisibilityLevel @default(TITLE_LOCATION)
  defaultLocationDisclosure   LocationDisclosure   @default(CITY)
  requiresTravelQuestions     Boolean              @default(false)
  requiresCommunicationsPlan  Boolean              @default(false)
  requiresComplianceReview    Boolean              @default(false)
  isSystemTemplate            Boolean              @default(false)
  isActive                    Boolean              @default(true)
  version                     Int                  @default(1)
  snapshotJson                Json?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  events   Event[]
  sections EventTemplateSection[]

  @@schema("kelly_calendar")
}

model EventTemplateSection {
  id         String @id @default(cuid())
  templateId String
  section    String
  payload    Json

  template EventTemplate @relation(fields: [templateId], references: [id])

  @@schema("kelly_calendar")
}

model PackingTemplate {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  isSystemTemplate Boolean @default(false)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items PackingTemplateItem[]

  @@schema("kelly_calendar")
}

model PackingTemplateItem {
  id         String          @id @default(cuid())
  templateId String
  category   PackingCategory @default(CAMPAIGN_MATERIAL)
  itemName   String
  quantity   Int             @default(1)

  template PackingTemplate @relation(fields: [templateId], references: [id])

  @@schema("kelly_calendar")
}

model ProgramFlowTemplate {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  isSystemTemplate Boolean  @default(false)
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items ProgramFlowTemplateItem[]

  @@schema("kelly_calendar")
}

model ProgramFlowTemplateItem {
  id           String           @id @default(cuid())
  templateId   String
  sequence     Int
  activityType FlowActivityType @default(CUSTOM)
  title        String

  template ProgramFlowTemplate @relation(fields: [templateId], references: [id])

  @@schema("kelly_calendar")
}

model ActionTemplate {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  isSystemTemplate Boolean  @default(false)
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items ActionTemplateItem[]

  @@schema("kelly_calendar")
}

model ActionTemplateItem {
  id         String      @id @default(cuid())
  templateId String
  phase      ActionPhase
  title      String

  template ActionTemplate @relation(fields: [templateId], references: [id])

  @@schema("kelly_calendar")
}

