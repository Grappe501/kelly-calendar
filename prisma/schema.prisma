}

// ─── Google Calendar OAuth + Routes (read-only import / estimated mileage) ─

/// V2.1 mission lifecycle (Prepare → Travel → Execute → Debrief → Follow-up → Complete)
enum MissionLifecyclePhase {
  PREPARE
  TRAVEL
  EXECUTE
  DEBRIEF
  FOLLOW_UP
  COMPLETE

  @@schema("kelly_calendar")
}

/// V2.1 mission operational status (draft-valid when incomplete)
enum MissionOperationalStatus {
  DRAFT
  PREPARING
  READY
  IN_PROGRESS
  DEBRIEFING
  FOLLOW_UP
  COMPLETE
  CANCELLED
  ARCHIVED

  @@schema("kelly_calendar")
}

/// V2.1 Prepare Mode briefing readiness — distinct from lifecycle phase and operational status.
