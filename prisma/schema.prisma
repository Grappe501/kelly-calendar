// Kelly Campaign Command Calendar — owned schema: kelly_calendar
// Step 4 AUTH-RBAC identity + Step 5 federated calendar foundation.
// Do not place tables in public. Do not mutate RedDirt schemas.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["kelly_calendar"]
}

