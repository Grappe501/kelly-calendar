/// Normalized Follow-up action — provenance + accountability state.
model MissionFollowUpAction {
  id                      String                      @id @default(cuid())
  followUpId              String
  sourceType              MissionFollowUpSourceType
  sourceRecordId          String?
  /// Deterministic import key: missionId + sourceType + sourceRecordId
  importKey               String?
  sourceSnapshot          Json?
  title                   String
  description             String?
  status                  MissionFollowUpActionStatus @default(OPEN)
  priority                MissionFollowUpPriority     @default(NORMAL)
  ownerType               MissionFollowUpOwnerType    @default(UNASSIGNED)
  ownerUserId             String?
  ownerName               String?
  ownerRole               String?
  relatedPersonName       String?
  relatedOrganizationName String?
  dueAt                   DateTime?
  nextCheckAt             DateTime?
  waitingReason           String?
  blockedReason           String?
  completionSummary       String?
  completionEvidence      Json                        @default("[]")
  completedAt             DateTime?
  cancelledAt             DateTime?
  cancellationReason      String?
  createdByUserId         String?
  updatedByUserId         String?
  completedByUserId       String?
  cancelledByUserId       String?
  sortOrder               Int                         @default(0)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  followUp MissionFollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)

  @@unique([followUpId, importKey])
  @@index([followUpId, status])
  @@index([status, dueAt])
  @@index([sourceType])
  @@schema("kelly_calendar")
}

