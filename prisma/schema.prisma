// ─── A. Calendar registry ────────────────────────────────────────────

model CalendarGroup {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  description   String?
  displayOrder  Int       @default(0)
  isSystemGroup Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  archivedAt    DateTime?

  calendars Calendar[]

  @@schema("kelly_calendar")
}

model Calendar {
  id                         String               @id @default(cuid())
  slug                       String               @unique
  name                       String
  shortName                  String?
  description                String?
  calendarType               CalendarType
  calendarGroupId            String?
  ownerUserId                String?
  managingTeamId             String?
  isSystemCalendar           Boolean              @default(false)
  isCommandCalendar          Boolean              @default(false)
  isActive                   Boolean              @default(true)
  defaultVisibility          EventVisibilityLevel @default(TITLE_LOCATION)
  defaultLocationDisclosure  LocationDisclosure   @default(CITY)
  defaultRollupMode          RollupMode           @default(TITLE_LOCATION)
  defaultEventDurationMinutes Int                 @default(60)
  allowsPublicEvents         Boolean              @default(false)
  allowsExternalImport       Boolean              @default(true)
  allowsExternalExport       Boolean              @default(false)
  requiresApproval           Boolean              @default(false)
  allowsDirectEventCreation  Boolean              @default(true)
  displayOrder               Int                  @default(0)
  displayColorToken          ColorToken           @default(events)
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  archivedAt                 DateTime?

  calendarGroup          CalendarGroup?            @relation(fields: [calendarGroupId], references: [id])
  memberships            CalendarMembership[]
  teamBindings           CalendarTeamBinding[]
  rollupRulesAsSource    CalendarRollupRule[]      @relation("RollupSource")
  rollupRulesAsTarget    CalendarRollupRule[]      @relation("RollupTarget")
  viewLayers             CalendarViewLayer[]
  primaryEvents          Event[]                   @relation("PrimaryCalendar")
  eventMemberships       EventCalendarMembership[]

  @@index([calendarType])
  @@index([isCommandCalendar])
  @@schema("kelly_calendar")
}

model CalendarMembership {
  id                         String              @id @default(cuid())
  calendarId                 String
  userId                     String
  accessLevel                CalendarAccessLevel @default(NO_ACCESS)
  canViewParticipants        Boolean             @default(false)
  canViewNotes               Boolean             @default(false)
  canViewFiles               Boolean             @default(false)
  canViewTravelDetails       Boolean             @default(false)
  canViewCommunicationsPlan  Boolean             @default(false)
  canViewFundraisingDetails  Boolean             @default(false)
  canViewSecurityDetails     Boolean             @default(false)
  canCreateEvents            Boolean             @default(false)
  canEditEvents              Boolean             @default(false)
  canArchiveEvents           Boolean             @default(false)
  canDeleteEvents            Boolean             @default(false)
  canManageMemberships       Boolean             @default(false)
  startsAt                   DateTime            @default(now())
  endsAt                     DateTime?
  grantedByUserId            String?
  grantReason                String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  revokedAt                  DateTime?
  revokedByUserId            String?

  calendar Calendar @relation(fields: [calendarId], references: [id])

  @@index([userId])
  @@index([calendarId])
  @@index([userId, calendarId, revokedAt])
  @@schema("kelly_calendar")
}

model CalendarTeamBinding {
  id                 String              @id @default(cuid())
  calendarId         String
  teamId             String
  accessLevel        CalendarAccessLevel @default(VIEW_LIMITED)
  sectionPermissions Json?
  startsAt           DateTime            @default(now())
  endsAt             DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  revokedAt          DateTime?

  calendar Calendar @relation(fields: [calendarId], references: [id])

  @@index([teamId])
  @@index([calendarId])
  @@schema("kelly_calendar")
}

model CalendarRollupRule {
  id                 String     @id @default(cuid())
  sourceCalendarId   String
  targetCalendarId   String
  rollupMode         RollupMode @default(TITLE_LOCATION)
  includeTentative   Boolean    @default(true)
  includeCancelled   Boolean    @default(false)
  includeCompleted   Boolean    @default(true)
  includeTasks       Boolean    @default(false)
  includeMilestones  Boolean    @default(true)
  includeLocation    Boolean    @default(true)
  includeSafeTitle   Boolean    @default(true)
  includeCalendarName Boolean   @default(true)
  priority           Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  sourceCalendar Calendar @relation("RollupSource", fields: [sourceCalendarId], references: [id])
  targetCalendar Calendar @relation("RollupTarget", fields: [targetCalendarId], references: [id])

  @@index([targetCalendarId])
  @@schema("kelly_calendar")
}

model CalendarSavedView {
  id               String   @id @default(cuid())
  ownerUserId      String?
  name             String
  description      String?
  isDefault        Boolean  @default(false)
  isShared         Boolean  @default(false)
  isSystemView     Boolean  @default(false)
  sharedWithTeamId String?
  dateRangeMode    String?
  viewMode         String?
  filtersJson      Json?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  archivedAt       DateTime?

  layers CalendarViewLayer[]

  @@schema("kelly_calendar")
}

model CalendarViewLayer {
  id           String   @id @default(cuid())
  savedViewId  String
  calendarId   String
  enabled      Boolean  @default(true)
  displayOrder Int      @default(0)
  displayMode  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  savedView CalendarSavedView @relation(fields: [savedViewId], references: [id])
  calendar  Calendar          @relation(fields: [calendarId], references: [id])

  @@schema("kelly_calendar")
}

model EventNumberCounter {
  year      Int @id
  nextValue Int @default(1)

  @@schema("kelly_calendar")
}

// ─── B. Canonical events ─────────────────────────────────────────────

model Event {
  id                          String                 @id @default(cuid())
  eventNumber                 String                 @unique
  sourceType                  String                 @default("MANUAL")
  createdByUserId             String?
  ownerUserId                 String?
  primaryCalendarId           String
  templateId                  String?
  templateVersion             Int?

  internalTitle               String
  campaignDisplayTitle        String
  restrictedDisplayTitle      String?
  publicTitle                 String?

  eventType                   String?
  eventSubtype                String?
  status                      EventStatus            @default(DRAFT)
  priority                    String                 @default("Normal")
  confirmationSource          String?
  confirmationStatus          String?

  startsAt                    DateTime
  endsAt                      DateTime
  timezone                    String                 @default("America/Chicago")
  isAllDay                    Boolean                @default(false)
  isMultiDay                  Boolean                @default(false)

  arrivalAt                   DateTime?
  departureAt                 DateTime?
  setupStartsAt               DateTime?
  breakdownEndsAt             DateTime?

  defaultVisibility           EventVisibilityLevel   @default(TITLE_LOCATION)
  locationDisclosure          LocationDisclosure     @default(CITY)
  sensitivityLevel            String                 @default("NORMAL")

  venueName                   String?
  streetAddress               String?
  addressLine2                String?
  city                        String?
  countyId                    String?
  state                       String                 @default("Arkansas")
  postalCode                  String?
  regionId                    String?
  locationNotes               String?
  virtualMeetingUrl           String?
  mapUrl                      String?

  publicDescription           String?
  campaignDescription         String?
  privateNotes                String?

  candidateAttendance         Boolean?
  candidateRole               String?
  expectedAttendance          Int?
  actualAttendance            Int?

  historicalReviewStatus      HistoricalReviewStatus @default(UNREVIEWED)
  historicalAttendanceConfirmed Boolean              @default(false)
  historicalOccurredConfirmed Boolean                @default(false)
  historicalReviewedByUserId  String?
  historicalReviewedAt        DateTime?

  isImported                  Boolean                @default(false)
  isRecurring                 Boolean                @default(false)
  recurrenceSeriesId          String?
  recurrenceRule              String?
  originalOccurrenceAt        DateTime?

  version                     Int                    @default(1)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  archivedAt                  DateTime?
  archivedByUserId            String?
  archiveReason               String?

  primaryCalendar      Calendar                   @relation("PrimaryCalendar", fields: [primaryCalendarId], references: [id])
  county               ArkansasCounty?            @relation(fields: [countyId], references: [id])
  region               ArkansasRegion?            @relation(fields: [regionId], references: [id])
  template             EventTemplate?             @relation(fields: [templateId], references: [id])
  calendarMemberships  EventCalendarMembership[]
  visibilityOverrides  EventVisibilityOverride[]
  sectionPermissions   EventSectionPermission[]
  statusHistory        EventStatusHistory[]
  eventTags            EventTag[]
  objectives           EventObjective[]
  programFlowItems     EventProgramFlowItem[]
  packingItems         EventPackingItem[]
  actionItems          EventActionItem[]
  staffAssignments     EventStaffAssignment[]
  communicationsItems  EventCommunicationsItem[]
  travelPlans          EventTravelPlan[]
  briefings            EventBriefing[]
  links                EventLink[]
  files                EventFile[]
  notes                EventNote[]
  outcomes             EventOutcome[]
  followups            EventFollowup[]
  eventPeople          EventPerson[]
  eventOrganizations   EventOrganization[]
  geographies          EventGeography[]
  importRecords        CalendarImportRecord[]
  externalIdentities   ExternalEventIdentity[]
  aiSuggestionRuns     AiSuggestionRun[]
  dataAccessLogs       DataAccessLog[]
  workflowApplications EventWorkflowApplication[]
  readinessSnapshots   EventReadinessSnapshot[]
  operationalRecommendations OperationalRecommendationRecord[]
  travelLegsFrom       CampaignTravelLeg[] @relation("TravelLegFrom")
  travelLegsTo         CampaignTravelLeg[] @relation("TravelLegTo")
  campaignMission      CampaignMission?

  @@index([startsAt, endsAt])
  @@index([status])
  @@index([primaryCalendarId])
  @@index([countyId])
  @@index([ownerUserId])
  @@index([historicalReviewStatus])
  @@index([archivedAt])
  @@schema("kelly_calendar")
}

model EventCalendarMembership {
  id                String              @id @default(cuid())
  eventId           String
  calendarId        String
  membershipType    EventMembershipType @default(RELATED)
  isPrimary         Boolean             @default(false)
  rollupOverride    RollupMode?
  visibilityOverride EventVisibilityLevel?
  createdByUserId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  removedAt         DateTime?

  event    Event    @relation(fields: [eventId], references: [id])
  calendar Calendar @relation(fields: [calendarId], references: [id])

  @@index([calendarId])
  @@index([eventId])
  @@schema("kelly_calendar")
}

model EventVisibilityOverride {
  id                       String               @id @default(cuid())
  eventId                  String
  targetType               VisibilityTargetType
  targetUserId             String?
  targetTeamId             String?
  targetRole               String?
  visibilityLevel          EventVisibilityLevel
  locationDisclosure       LocationDisclosure?
  canOpen                  Boolean              @default(false)
  canViewParticipants      Boolean              @default(false)
  canViewNotes             Boolean              @default(false)
  canViewFiles             Boolean              @default(false)
  canViewTravelDetails     Boolean              @default(false)
  canViewCommunications    Boolean              @default(false)
  canViewFundraising       Boolean              @default(false)
  canViewSecurity          Boolean              @default(false)
  createdByUserId          String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  revokedAt                DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@schema("kelly_calendar")
}

model EventSectionPermission {
  id              String               @id @default(cuid())
  eventId         String
  section         EventSection
  targetType      VisibilityTargetType
  targetUserId    String?
  targetTeamId    String?
  targetRole      String?
  accessLevel     CalendarAccessLevel  @default(NO_ACCESS)
  createdByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  revokedAt       DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId, section])
  @@schema("kelly_calendar")
}

model EventStatusHistory {
  id            String      @id @default(cuid())
  eventId       String
  fromStatus    EventStatus?
  toStatus      EventStatus
  changedByUserId String?
  reason        String?
  createdAt     DateTime    @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@schema("kelly_calendar")
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  eventTags EventTag[]

  @@schema("kelly_calendar")
}

model EventTag {
  id      String @id @default(cuid())
  eventId String
  tagId   String

  event Event @relation(fields: [eventId], references: [id])
  tag   Tag   @relation(fields: [tagId], references: [id])

  @@unique([eventId, tagId])
  @@schema("kelly_calendar")
}

// ─── C. Event operations ─────────────────────────────────────────────

model EventObjective {
  id                String        @id @default(cuid())
  eventId           String
  objectiveType     ObjectiveType @default(OTHER)
  isPrimary         Boolean       @default(false)
  description       String?
  successDefinition String?
  targetAudience    String?
  desiredOutcome    String?
  priority          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@schema("kelly_calendar")
}

model EventProgramFlowItem {
  id                 String           @id @default(cuid())
  eventId            String
  sequence           Int
  startsAt           DateTime?
  endsAt             DateTime?
  durationMinutes    Int?
  activityType       FlowActivityType @default(CUSTOM)
  title              String
  description        String?
  responsibleUserId  String?
  responsibleTeamId  String?
  locationLabel      String?
  candidateAction    String?
  requiredMaterials  String?
  status             TaskStatus       @default(NOT_STARTED)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  completedAt        DateTime?

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId, sequence])
  @@schema("kelly_calendar")
}

model EventPackingItem {
  id             String          @id @default(cuid())
  eventId        String
  templateItemId String?
  category       PackingCategory @default(CUSTOM)
  itemName       String
  quantity       Int             @default(1)
  state          ChecklistState  @default(NEEDED)
  assignedUserId String?
  assignedTeamId String?
  neededBy       DateTime?
  packedAt       DateTime?
  loadedAt       DateTime?
  deliveredAt    DateTime?
  returnedAt     DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@schema("kelly_calendar")
}

model EventActionItem {
  id                String       @id @default(cuid())
  eventId           String
  phase             ActionPhase
  actionType        String?
  title             String
  description       String?
  assignedUserId    String?
  assignedTeamId    String?
  dueAt             DateTime?
  status            TaskStatus   @default(NOT_STARTED)
  priority          String?
  requiresApproval  Boolean      @default(false)
  approvalRequestId String?
  completedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([assignedUserId])
  @@index([assignedTeamId])
  @@index([dueAt])
  @@index([status])
  @@index([eventId, phase])
  @@schema("kelly_calendar")
}

model EventStaffAssignment {
  id             String        @id @default(cuid())
  eventId        String
  roleType       StaffRoleType
  assignedUserId String?
  assignedTeamId String?
  status         TaskStatus    @default(NOT_STARTED)
  startsAt       DateTime?
  endsAt         DateTime?
  instructions   String?
  confirmedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@schema("kelly_calendar")
}

model EventCommunicationsItem {
  id             String         @id @default(cuid())
  eventId        String
  channel        CommChannel
  communicationType CommType    @default(OTHER)
  audience       String?
  objective      String?
  ownerUserId    String?
  ownerTeamId    String?
  draftDueAt     DateTime?
  approvalDueAt  DateTime?
  publishAt      DateTime?
  publishedAt    DateTime?
