  @@schema("kelly_calendar")
}

/// Provider-neutral external identity + sync metadata foundation (Mobilize-ready).
/// Does not perform network calls. Local models remain system of record.
/// Secrets must never be stored here — use encrypted credential stores separately.
model ExternalObjectReference {
  id                   String                 @id @default(cuid())
  /// Soft campaign scope (no Campaign table). Default singleton Kelly campaign.
  campaignScopeKey     String                 @default("KELLY")
  provider             ExternalProvider
  objectType           ExternalObjectType
  /// Remote provider object id (Mobilize event id, etc.). Never fabricate.
  externalObjectId     String
  /// Soft local binding — e.g. CampaignMission, Event. Not a hard FK.
  localObjectType      String?
  localObjectId        String?
  remoteVersion        String?
  remoteCreatedAt      DateTime?
  remoteUpdatedAt      DateTime?
  remoteDeletedAt      DateTime?
  contentFingerprint   String?
  lastObservedAt       DateTime?
  lastSuccessfulSyncAt DateTime?
  lastAttemptAt        DateTime?
  syncDirection        SyncDirection          @default(NONE)
  syncStatus           SyncStatus             @default(NOT_CONFIGURED)
  provenance           ExternalSyncProvenance @default(UNKNOWN)
  conflictState        ExternalConflictState  @default(NONE)
  /// Stable idempotency key for imports/publishes. Unique per provider when set.
  idempotencyKey       String?
  lastErrorCode        String?
  /// Safe operator-facing summary — never store secrets or tokens.
  lastErrorSummary     String?
  createdByUserId      String?
  updatedByUserId      String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  archivedAt           DateTime?

  @@unique([campaignScopeKey, provider, objectType, externalObjectId])
  @@unique([provider, idempotencyKey])
  @@index([provider, syncStatus])
  @@index([localObjectType, localObjectId])
  @@index([conflictState])
  @@index([campaignScopeKey, provider])
  @@schema("kelly_calendar")
}

/// Mobilize / external provider connection metadata. Credentials stay in env only.
enum ExternalIntegrationConnectionStatus {
  NOT_CONFIGURED
  CONFIGURED_UNVERIFIED
  CONNECTED
  INVALID_CREDENTIALS
  ORGANIZATION_MISMATCH
  INSUFFICIENT_ACCESS
