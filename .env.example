# =============================================================================
# Kelly Campaign Command Calendar — environment template
# Never commit real values. Production uses Netlify-injected variables.
# Local: calendar .env.local wins; approved missing keys may fall back to RedDirt.
# =============================================================================

# Public (browser-safe)
NEXT_PUBLIC_APP_NAME=Kelly Campaign Command Calendar
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CAMPAIGN_TIMEZONE=America/Chicago
NEXT_PUBLIC_ELECTION_DATE=2026-11-03
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only
DATABASE_URL=
DIRECT_URL=
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_SESSION_SECRET=
INTERNAL_API_SECRET=
LOG_LEVEL=info

# Local RedDirt filesystem fallback (disabled on Netlify/CI)
ENV_FALLBACK_TO_REDDIRT=true
