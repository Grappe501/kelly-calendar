# =============================================================================
# Kelly Campaign Command Calendar — environment template
# Copy to .env.local (gitignored). Shared secrets may live in ../RedDirt/.env.local
# Never commit real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Public site (embedded in client bundle — no secrets)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Election anchor (optional override)
# KCCC_ELECTION_DATE=2026-11-03

# -----------------------------------------------------------------------------
# Database — Step 5+ (Prisma, schema kelly_calendar)
# Fallback: ../RedDirt/.env.local
# -----------------------------------------------------------------------------
# DATABASE_URL=
# DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase Auth — Step 4+
# Fallback: ../RedDirt/.env.local
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# OpenAI — Step 16+ (SERVER ONLY — never NEXT_PUBLIC_)
# Fallback: ../RedDirt/.env.local
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Travel defaults (optional)
# -----------------------------------------------------------------------------
# KCCC_DEFAULT_TRAVEL_BUFFER_MIN=15
# KCCC_DEFAULT_PARKING_BUFFER_MIN=10
