# =============================================================================
# Kelly Campaign Command Calendar — environment template
# Never commit real values. Production uses Netlify-injected variables.
# Local: calendar .env.local wins; approved missing keys may fall back to RedDirt.
# =============================================================================

# Public (browser-safe)
NEXT_PUBLIC_APP_NAME=Kelly Campaign Command Calendar
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CAMPAIGN_TIMEZONE=America/Chicago
NEXT_PUBLIC_ELECTION_DATE=2026-11-03
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only
DATABASE_URL=
DIRECT_URL=
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Required for Step 4 sessions (min 32 chars). Prefer: npm run auth:ensure-secret
APP_SESSION_SECRET=
INTERNAL_API_SECRET=
LOG_LEVEL=info

# Optional: override synthetic seed password for npm run auth:seed
# KCCC_SEED_PASSWORD=

# Private Google Calendar secret iCal address (server-only, read-only sync).
# Put the real value only in .env.local / Netlify env — never commit it.
# Do not paste into chat, docs, logs, or browser forms.
KCCC_GOOGLE_CALENDAR_ICAL_URL=

# Google Calendar OAuth (read-only) + Routes (estimated mileage)
# Real values only in .env.local / Netlify — never commit.
KCCC_GOOGLE_CLIENT_ID=
KCCC_GOOGLE_CLIENT_SECRET=
KCCC_GOOGLE_CALENDAR_ID=primary
KCCC_GOOGLE_TOKEN_ENCRYPTION_KEY=
KCCC_GOOGLE_OAUTH_REDIRECT_URI=
KCCC_GOOGLE_MAPS_ROUTES_API_KEY=
KCCC_GOOGLE_SYNC_ENABLED=false
KCCC_GOOGLE_ROUTES_ENABLED=false
KCCC_GOOGLE_HISTORY_START=2025-11-01T00:00:00-05:00

# Local RedDirt filesystem fallback (disabled on Netlify/CI)
ENV_FALLBACK_TO_REDDIRT=true
